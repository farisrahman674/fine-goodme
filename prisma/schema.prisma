generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

enum ImageRole {
  IMAGE_PRODUCT
  IMAGE_DECOR
}
enum ProductStatus {
  ACTIVE
  INACTIVE
}
model Product {
  id          String   @id @default(uuid())
  slug        String   @unique
  category    String
  categoryNew Json?
  subCategory Json?
  description Json
  rating      Float
  reviewCount Int
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime @default(now())

  variants    Variant[]
}

model Variant {
  id        String   @id @default(uuid())
  model     String
  images     Image[]

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  specs     Spec[]
}

model Image {
  id        String   @id @default(uuid())
  url       String
  role      ImageRole  // front, back, side
  variantId String
  variant   Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model Spec {
  id          String   @id @default(uuid())
  label       String
  value       String
  isHighlight Boolean  @default(false)

  variantId   String
  variant     Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
}